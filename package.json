{
  "name": "cardsense",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:import": "tsx scripts/import-csv.ts",
    "db:relabel": "tsx scripts/relabel-segments.ts",
    "ml:train": "python -m analysis.scripts.run_clustering",
    "ml:segments": "python -m analysis.scripts.generate_segments",
    "docs:serve": "mkdocs serve",
    "docs:build": "mkdocs build"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "lucide-react": "0.469.0",
    "next": "^16.2.10",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "papaparse": "5.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.54.2",
    "recharts": "2.15.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.17.12",
    "@types/papaparse": "5.3.15",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "15.3.9",
    "jsdom": "25.0.1",
    "openapi-types": "^12.1.3",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.17",
    "ts-node": "10.9.2",
    "tsx": "^4.23.1",
    "typescript": "5.7.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
